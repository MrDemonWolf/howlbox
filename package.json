{
  "name": "howlbox",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "@types/node": "^22.13.14",
      "lucide-react": "^1.21.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.7",
      "react-dom": "^19.2.7",
      "sonner": "^2.0.7",
      "@types/react": "^19.2.17",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.3.1"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "dev:web": "turbo run dev -F web",
    "check": "biome check --write ."
  },
  "dependencies": {
    "@howlbox/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@howlbox/config": "workspace:*",
    "@types/node": "catalog:",
    "turbo": "^2.10.2",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.14"
}
